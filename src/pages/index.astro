---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import {
	collectionName,
	collectionPath,
	compareProductsForDisplay,
	isAccessoryProduct,
	priceLabel,
	productInquiryHref,
	site,
} from '../lib/catalog';

const products = (await getCollection('products')).sort(compareProductsForDisplay);
const heroProduct =
	products.find((product) => product.data.sku === 'PMS011') ??
	products.find((product) => {
		const title = product.data.title.toLowerCase();
		return product.data.image && product.data.category?.includes('RM 011') && !title.includes('screw') && !title.includes('box');
	}) ?? products.find((product) => product.data.image) ?? products[0];

const featuredProducts = products
	.filter((product) => {
		const title = product.data.title.toLowerCase();
		return product.data.image && !isAccessoryProduct(product) && !title.includes('strap for');
	})
	.slice(0, 12);

const collectionCounts = products.reduce<Map<string, { count: number; path: string }>>((counts, product) => {
	const name = collectionName(product.data.category);
	const current = counts.get(name) ?? { count: 0, path: collectionPath(product.data.category) };
	current.count += 1;
	counts.set(name, current);
	return counts;
}, new Map());

const topCollections = [...collectionCounts.entries()].sort((a, b) => b[1].count - a[1].count).slice(0, 12);
const heroPath = `/products/${heroProduct.id}/`;
const heroInquiry = productInquiryHref(heroProduct.data.title, heroProduct.data.sku, heroPath);
const storyProducts = featuredProducts.slice(1, 5);
---

<BaseLayout title="Mirck | Richard Mille Private Catalogue" className="home-page">
	<main>
		<section class="home-hero" aria-labelledby="hero-title">
			<div class="home-hero__copy">
				<p class="kicker">{site.tagline}</p>
				<h1 id="hero-title" class="display-title">Richard Mille</h1>
				<p class="lead">
					Private catalogue, collection-led browsing, and direct WhatsApp inquiry for high-demand RM references.
				</p>
				<div class="button-row">
					<a class="button" href="/products/">View Catalogue</a>
					<a class="button button--ghost" href="#collections">Browse Collections</a>
					<a class="button button--whatsapp" href={heroInquiry}>WhatsApp This Piece</a>
				</div>
			</div>
			<a class="home-hero__watch" href={heroPath} aria-label={`Open ${heroProduct.data.title}`}>
				<img src={heroProduct.data.image} alt={heroProduct.data.title} loading="eager" />
			</a>
			<div class="home-hero__caption">
				<span>{collectionName(heroProduct.data.category)}</span>
				<strong>{heroProduct.data.title}</strong>
				<small>{priceLabel(heroProduct.data.price)}</small>
			</div>
		</section>

		<section class="page-shell stats-strip" aria-label="Catalogue statistics">
			<div><strong>{products.length.toLocaleString('en-US')}</strong><span>Richard Mille products</span></div>
			<div><strong>{collectionCounts.size}</strong><span>Collections and families</span></div>
			<div><strong>WhatsApp</strong><span>Direct private inquiry</span></div>
		</section>

		<section class="page-shell editorial-section" aria-labelledby="editorial-title">
			<div class="section-head">
				<h2 id="editorial-title">Precision-led presentation.</h2>
				<p>Large product imagery, restrained labels, and collection paths built for fast client selection.</p>
			</div>
			<div class="editorial-grid">
				{
					storyProducts.map((product, index) => (
						<a class:list={['editorial-tile', index === 0 && 'editorial-tile--wide']} href={`/products/${product.id}/`}>
							<img src={product.data.image} alt={product.data.title} loading="lazy" />
							<span>{collectionName(product.data.category)}</span>
							<strong>{product.data.title}</strong>
						</a>
					))
				}
			</div>
		</section>

		<section id="collections" class="page-shell">
			<div class="section-head">
				<h2>Collections</h2>
				<p>Start with the strongest RM families, then open any reference for gallery and inquiry.</p>
			</div>
			<div class="collection-index">
				{
					topCollections.map(([name, data], index) => (
						<a href={data.path}>
							<span>{String(index + 1).padStart(2, '0')}</span>
							<strong>{name}</strong>
							<small>{data.count.toLocaleString('en-US')} pieces</small>
						</a>
					))
				}
			</div>
		</section>

		<section class="client-desk" aria-labelledby="desk-title">
			<div class="page-shell client-desk__inner">
				<div>
					<p class="kicker">Client Desk</p>
					<h2 id="desk-title">Client desk</h2>
				</div>
				<div class="client-desk__items">
					<div><strong>Free worldwide shipping</strong><span>Commercial positioning aligned with Mirckclone's main store promise.</span></div>
					<div><strong>Private availability check</strong><span>Send any reference through WhatsApp and keep the product link attached.</span></div>
					<div><strong>Photo request workflow</strong><span>Ask for more angles, batch details, and payment timing before purchase.</span></div>
					<div><strong>Collection-led browsing</strong><span>RM 011, RM 055, RM 35-02, RM 052 and other families stay one tap away.</span></div>
				</div>
			</div>
		</section>

		<section class="page-shell">
			<div class="section-head">
				<h2>Selected references</h2>
				<p>Product tiles keep the watch visible first, with family, SKU and inquiry price below.</p>
			</div>
			<div class="product-grid">
				{featuredProducts.map((product, index) => <ProductCard product={product} priority={index < 4} />)}
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.home-hero {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 0.84fr) minmax(420px, 0.88fr);
		align-items: center;
		min-height: min(680px, calc(100svh - 73px));
		padding: 38px 54px 72px;
		background:
			linear-gradient(90deg, rgba(246, 244, 239, 0.98) 0%, rgba(246, 244, 239, 0.82) 50%, rgba(246, 244, 239, 0.35) 100%),
			linear-gradient(180deg, #ffffff, #dfdbd1);
		overflow: hidden;
	}

	.home-hero::after {
		position: absolute;
		right: 0;
		bottom: 0;
		width: 42%;
		height: 1px;
		background: var(--ink);
		content: "";
	}

	.home-hero__copy {
		position: relative;
		z-index: 2;
		display: grid;
		gap: 22px;
		max-width: 760px;
	}

	.home-hero__copy .lead {
		max-width: 500px;
	}

	.home-hero__watch {
		position: relative;
		z-index: 1;
		display: grid;
		place-items: center;
		min-height: 480px;
	}

	.home-hero__watch img {
		width: min(100%, 680px);
		max-height: 58vh;
		object-fit: contain;
		filter: drop-shadow(0 38px 44px rgba(0, 0, 0, 0.26));
	}

	.home-hero__caption {
		position: absolute;
		right: 54px;
		bottom: 34px;
		z-index: 3;
		display: grid;
		gap: 6px;
		width: min(390px, calc(100% - 36px));
		border-left: 2px solid var(--red);
		padding: 14px 0 14px 18px;
		background: rgba(246, 244, 239, 0.9);
		backdrop-filter: blur(10px);
	}

	.home-hero__caption span,
	.home-hero__caption small {
		color: var(--muted);
		font-family: "Inter Tight", Inter, Arial, sans-serif;
		font-size: 0.74rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.home-hero__caption strong {
		font-family: "Inter Tight", Inter, Arial, sans-serif;
		font-size: 1.18rem;
		font-weight: 500;
		line-height: 1.14;
		text-transform: uppercase;
	}

	.stats-strip {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		border-top: 1px solid var(--ink);
		border-bottom: 1px solid var(--line);
	}

	.stats-strip div {
		display: grid;
		gap: 8px;
		padding: 24px 0;
		border-right: 1px solid var(--line);
	}

	.stats-strip div:last-child {
		border-right: 0;
		padding-left: clamp(0px, 2vw, 22px);
	}

	.stats-strip strong {
		font-family: "Inter Tight", Inter, Arial, sans-serif;
		font-size: 2.7rem;
		font-weight: 500;
		text-transform: uppercase;
	}

	.stats-strip span {
		color: var(--muted);
		font-family: "Inter Tight", Inter, Arial, sans-serif;
		font-size: 0.78rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.collection-index {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		border-top: 1px solid var(--line);
		border-left: 1px solid var(--line);
	}

	.collection-index a {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 8px 18px;
		min-height: 128px;
		border-right: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		padding: clamp(18px, 2.4vw, 30px);
		background: var(--paper);
	}

	.collection-index a:hover {
		background: var(--white);
	}

	.collection-index span {
		color: var(--red);
		font-size: 0.72rem;
		font-weight: 900;
	}

	.collection-index strong {
		font-family: "Inter Tight", Inter, Arial, sans-serif;
		font-size: 1.75rem;
		font-weight: 500;
		line-height: 1.05;
		text-transform: uppercase;
	}

	.collection-index small {
		grid-column: 2;
		color: var(--muted);
		font-family: "Inter Tight", Inter, Arial, sans-serif;
		font-size: 0.78rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.editorial-section {
		padding-bottom: clamp(26px, 5vw, 72px);
	}

	.editorial-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		border-top: 1px solid var(--line);
		border-left: 1px solid var(--line);
	}

	.editorial-tile {
		position: relative;
		display: grid;
		align-content: end;
		min-height: 560px;
		border-right: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		padding: 30px;
		background: #0b0b0c;
		color: var(--white);
		overflow: hidden;
	}

	.editorial-tile--wide {
		grid-column: span 2;
	}

	.editorial-tile img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: contain;
		padding: 58px;
		opacity: 0.82;
		transition: transform 260ms ease, opacity 260ms ease;
	}

	.editorial-tile::after {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, transparent 30%, rgba(0, 0, 0, 0.76));
		content: "";
	}

	.editorial-tile:hover img {
		opacity: 1;
		transform: scale(1.04);
	}

	.editorial-tile span,
	.editorial-tile strong {
		position: relative;
		z-index: 1;
	}

	.editorial-tile span {
		margin-bottom: 10px;
		color: #ff3848;
		font-family: "Inter Tight", Inter, Arial, sans-serif;
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.editorial-tile strong {
		max-width: 520px;
		font-family: "Inter Tight", Inter, Arial, sans-serif;
		font-size: 2.55rem;
		font-weight: 500;
		line-height: 1;
		text-transform: uppercase;
	}

	.client-desk {
		margin-top: 92px;
		background: var(--black);
		color: var(--white);
	}

	.client-desk__inner {
		display: grid;
		grid-template-columns: minmax(0, 0.72fr) minmax(0, 1fr);
		gap: 86px;
		padding-top: 96px;
		padding-bottom: 96px;
	}

	.client-desk h2 {
		margin: 0;
		font-family: "Inter Tight", Inter, Arial, sans-serif;
		font-size: 5.4rem;
		font-weight: 500;
		line-height: 0.95;
		text-transform: uppercase;
	}

	.client-desk__items {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		border-top: 1px solid rgba(255, 255, 255, 0.22);
		border-left: 1px solid rgba(255, 255, 255, 0.22);
	}

	.client-desk__items div {
		display: grid;
		gap: 12px;
		min-height: 150px;
		border-right: 1px solid rgba(255, 255, 255, 0.22);
		border-bottom: 1px solid rgba(255, 255, 255, 0.22);
		padding: 26px;
	}

	.client-desk__items strong {
		font-family: "Inter Tight", Inter, Arial, sans-serif;
		font-size: 1.35rem;
		font-weight: 500;
		line-height: 1.1;
		text-transform: uppercase;
	}

	.client-desk__items span {
		color: rgba(255, 255, 255, 0.68);
		line-height: 1.62;
	}

	@media (max-width: 900px) {
		.home-hero {
			grid-template-columns: 1fr;
			min-height: auto;
			padding: 48px 18px 140px;
		}

		.home-hero__watch {
			min-height: 390px;
		}

		.collection-index {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.editorial-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.client-desk__inner {
			grid-template-columns: 1fr;
			gap: 34px;
		}
	}

	@media (max-width: 620px) {
		.home-hero {
			padding-top: 32px;
		}

		.home-hero__caption {
			left: 18px;
			right: 18px;
			bottom: 72px;
		}

		.stats-strip,
		.collection-index,
		.editorial-grid,
		.client-desk__items {
			grid-template-columns: 1fr;
		}

		.editorial-tile {
			min-height: 430px;
			padding: 22px;
		}

		.editorial-tile strong,
		.client-desk h2 {
			font-size: 2.35rem;
		}

		.editorial-tile--wide {
			grid-column: auto;
		}

		.stats-strip div {
			border-right: 0;
			border-bottom: 1px solid var(--line);
		}
	}
</style>
