---
import { getCollection } from 'astro:content';

const products = await getCollection('products');
const sortedProducts = products.sort((a, b) => a.data.title.localeCompare(b.data.title));
const featuredProducts = sortedProducts.slice(0, 12);
const heroProduct = sortedProducts.find((product) => product.data.brand === 'Richard Mille') ?? sortedProducts[0];

const brandCounts = sortedProducts.reduce<Map<string, number>>((counts, product) => {
	counts.set(product.data.brand, (counts.get(product.data.brand) ?? 0) + 1);
	return counts;
}, new Map());

const topBrands = [...brandCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 8);
const productCountLabel = `${sortedProducts.length.toLocaleString('en-US')} pieces`;

const priceLabel = (price?: number) =>
	typeof price === 'number'
		? new Intl.NumberFormat('en-US', {
				style: 'currency',
				currency: 'USD',
				maximumFractionDigits: 0,
			}).format(price)
		: 'Price on request';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Mirck | High-End Watch Catalogue</title>
		<meta
			name="description"
			content="Mirck is a curated high-end watch catalogue with premium collections from Rolex, Richard Mille, Patek Philippe, Audemars Piguet, Cartier, Omega, and more."
		/>
		<style>
			:root {
				color: #f4efe5;
				background: #090b0d;
				font-family:
					Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				font-size: 16px;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				background:
					linear-gradient(180deg, rgba(9, 11, 13, 0.34), #090b0d 650px),
					radial-gradient(circle at 72% 12%, rgba(178, 134, 72, 0.22), transparent 34%),
					#090b0d;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			img {
				display: block;
			}

			.site-header,
			main {
				width: min(1240px, calc(100% - 32px));
				margin: 0 auto;
			}

			.site-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 24px;
				padding: 24px 0;
			}

			.brand-mark {
				font-size: 1rem;
				font-weight: 850;
				letter-spacing: 0.12em;
				text-transform: uppercase;
			}

			.nav-links {
				display: flex;
				align-items: center;
				gap: 10px;
				flex-wrap: wrap;
			}

			.nav-links a {
				border: 1px solid rgba(244, 239, 229, 0.18);
				border-radius: 7px;
				padding: 10px 13px;
				color: #d9d1c2;
				font-size: 0.88rem;
				font-weight: 750;
			}

			.hero {
				display: grid;
				grid-template-columns: minmax(0, 0.92fr) minmax(320px, 1.08fr);
				gap: 56px;
				align-items: center;
				padding: 54px 0 72px;
			}

			.kicker {
				margin: 0 0 16px;
				color: #c89b5a;
				font-size: 0.78rem;
				font-weight: 850;
				letter-spacing: 0.18em;
				text-transform: uppercase;
			}

			h1 {
				margin: 0;
				max-width: 800px;
				font-size: clamp(3.1rem, 7.5vw, 7.4rem);
				line-height: 0.9;
				font-weight: 900;
			}

			.hero-copy {
				margin: 24px 0 0;
				max-width: 620px;
				color: #c8c1b7;
				font-size: 1.08rem;
				line-height: 1.75;
			}

			.hero-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 12px;
				margin-top: 30px;
			}

			.button {
				border-radius: 7px;
				padding: 13px 17px;
				font-weight: 850;
			}

			.button-primary {
				background: #d7a85e;
				color: #101010;
			}

			.button-secondary {
				border: 1px solid rgba(244, 239, 229, 0.2);
				color: #f4efe5;
			}

			.hero-media {
				position: relative;
				min-height: 560px;
				border: 1px solid rgba(244, 239, 229, 0.14);
				border-radius: 8px;
				background:
					linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02)),
					#151719;
				overflow: hidden;
			}

			.hero-media img {
				width: 100%;
				height: 100%;
				min-height: 560px;
				object-fit: cover;
			}

			.hero-card {
				position: absolute;
				left: 18px;
				right: 18px;
				bottom: 18px;
				border: 1px solid rgba(244, 239, 229, 0.16);
				border-radius: 8px;
				background: rgba(9, 11, 13, 0.78);
				backdrop-filter: blur(14px);
				padding: 18px;
			}

			.hero-card span {
				color: #c89b5a;
				font-size: 0.78rem;
				font-weight: 850;
				text-transform: uppercase;
			}

			.hero-card h2 {
				margin: 8px 0 0;
				font-size: 1.2rem;
				line-height: 1.25;
			}

			.stats {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 12px;
				margin: 0 0 54px;
			}

			.stat {
				border-top: 1px solid rgba(244, 239, 229, 0.16);
				padding-top: 18px;
			}

			.stat strong {
				display: block;
				font-size: clamp(1.8rem, 4vw, 3rem);
			}

			.stat span {
				color: #a8a095;
				font-size: 0.9rem;
			}

			.section-heading {
				display: flex;
				align-items: end;
				justify-content: space-between;
				gap: 20px;
				border-top: 1px solid rgba(244, 239, 229, 0.13);
				padding-top: 30px;
				margin: 0 0 22px;
			}

			.section-heading h2 {
				margin: 0;
				font-size: clamp(1.6rem, 3vw, 2.6rem);
			}

			.section-heading p {
				margin: 0;
				max-width: 420px;
				color: #a8a095;
				line-height: 1.6;
			}

			.brand-grid {
				display: grid;
				grid-template-columns: repeat(4, minmax(0, 1fr));
				gap: 12px;
				margin-bottom: 60px;
			}

			.brand-tile {
				border: 1px solid rgba(244, 239, 229, 0.13);
				border-radius: 8px;
				background: rgba(255, 255, 255, 0.035);
				padding: 18px;
			}

			.brand-tile strong,
			.brand-tile span {
				display: block;
			}

			.brand-tile strong {
				font-size: 1.08rem;
			}

			.brand-tile span {
				margin-top: 8px;
				color: #c89b5a;
				font-size: 0.88rem;
			}

			.product-grid {
				display: grid;
				grid-template-columns: repeat(4, minmax(0, 1fr));
				gap: 16px;
				padding-bottom: 70px;
			}

			.product-card {
				display: grid;
				grid-template-rows: auto 1fr;
				min-width: 0;
				border: 1px solid rgba(244, 239, 229, 0.12);
				border-radius: 8px;
				background: rgba(255, 255, 255, 0.035);
				overflow: hidden;
			}

			.product-card img {
				width: 100%;
				aspect-ratio: 1 / 1;
				object-fit: cover;
				background: #151719;
			}

			.product-card__body {
				display: grid;
				gap: 10px;
				padding: 15px;
			}

			.product-card__brand {
				color: #c89b5a;
				font-size: 0.74rem;
				font-weight: 850;
				letter-spacing: 0.1em;
				text-transform: uppercase;
			}

			.product-card h3 {
				margin: 0;
				font-size: 1rem;
				line-height: 1.32;
			}

			.product-card__meta {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 12px;
				margin-top: auto;
				color: #d9d1c2;
				font-size: 0.86rem;
				font-weight: 800;
			}

			.stock {
				color: #8cc6a2;
			}

			@media (max-width: 980px) {
				.hero {
					grid-template-columns: 1fr;
				}

				.product-grid,
				.brand-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}
			}

			@media (max-width: 620px) {
				.site-header {
					align-items: flex-start;
					flex-direction: column;
				}

				.hero {
					padding-top: 30px;
					gap: 28px;
				}

				.hero-media,
				.hero-media img {
					min-height: 360px;
				}

				.stats,
				.product-grid,
				.brand-grid {
					grid-template-columns: 1fr;
				}

				.section-heading {
					align-items: flex-start;
					flex-direction: column;
				}
			}
		</style>
	</head>
	<body>
		<header class="site-header">
			<a class="brand-mark" href="/">Mirck</a>
			<nav class="nav-links" aria-label="Main navigation">
				<a href="/products/">Catalogue</a>
				<a href="/admin/">CMS Admin</a>
			</nav>
		</header>

		<main>
			<section class="hero" aria-labelledby="hero-title">
				<div>
					<p class="kicker">Private Watch Catalogue</p>
					<h1 id="hero-title">High-end watches, curated for serious buyers.</h1>
					<p class="hero-copy">
						Mirck presents a focused catalogue of luxury sports, dress, and complication watches,
						organized by maison, reference family, and availability for fast client selection.
					</p>
					<div class="hero-actions">
						<a class="button button-primary" href="/products/">View catalogue</a>
						<a class="button button-secondary" href="/admin/">Manage products</a>
					</div>
				</div>
				<a class="hero-media" href={`/products/${heroProduct.id}/`}>
					<img src={heroProduct.data.image} alt={heroProduct.data.title} loading="eager" />
					<div class="hero-card">
						<span>{heroProduct.data.brand}</span>
						<h2>{heroProduct.data.title}</h2>
					</div>
				</a>
			</section>

			<section class="stats" aria-label="Catalogue statistics">
				<div class="stat">
					<strong>{productCountLabel}</strong>
					<span>Live product catalogue</span>
				</div>
				<div class="stat">
					<strong>{topBrands.length}+</strong>
					<span>Core watch houses</span>
				</div>
				<div class="stat">
					<strong>24/7</strong>
					<span>Git-backed CMS updates</span>
				</div>
			</section>

			<section aria-labelledby="brands-title">
				<div class="section-heading">
					<h2 id="brands-title">Brands in focus</h2>
					<p>Browse the strongest product families first, from technical sports cases to classic dress references.</p>
				</div>
				<div class="brand-grid">
					{
						topBrands.map(([brand, count]) => (
							<a class="brand-tile" href="/products/">
								<strong>{brand}</strong>
								<span>{count.toLocaleString('en-US')} pieces</span>
							</a>
						))
					}
				</div>
			</section>

			<section aria-labelledby="featured-title">
				<div class="section-heading">
					<h2 id="featured-title">Selected arrivals</h2>
					<p>A first look at the current catalogue. Open the full catalogue for every imported reference.</p>
				</div>
				<div class="product-grid">
					{
						featuredProducts.map((product) => (
							<a class="product-card" href={`/products/${product.id}/`}>
								<img src={product.data.image} alt={product.data.title} loading="lazy" />
								<div class="product-card__body">
									<span class="product-card__brand">{product.data.brand}</span>
									<h3>{product.data.title}</h3>
									<div class="product-card__meta">
										<span>{priceLabel(product.data.price)}</span>
										<span class="stock">{product.data.in_stock ? 'Available' : 'Unavailable'}</span>
									</div>
								</div>
							</a>
						))
					}
				</div>
			</section>
		</main>
	</body>
</html>
