---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import {
	collectionName,
	collectionPath,
	compareProductsForDisplay,
	isAccessoryProduct,
	productInquiryHref,
	site,
} from '../lib/catalog';

const products = (await getCollection('products')).sort(compareProductsForDisplay);
const heroProduct =
	products.find((product) => product.data.sku === 'PMS011') ??
	products.find((product) => product.data.image && product.data.category?.includes('RM 011')) ??
	products.find((product) => product.data.image) ??
	products[0];

const featuredProducts = products
	.filter((product) => product.data.image && !isAccessoryProduct(product))
	.slice(0, 12);

const collectionCounts = products.reduce<Map<string, { count: number; path: string; sample?: typeof products[number] }>>(
	(counts, product) => {
		const name = collectionName(product.data.category);
		const current = counts.get(name) ?? { count: 0, path: collectionPath(product.data.category), sample: product };
		current.count += 1;
		if (!current.sample?.data.image && product.data.image) current.sample = product;
		counts.set(name, current);
		return counts;
	},
	new Map(),
);

const topCollections = [...collectionCounts.entries()].sort((a, b) => b[1].count - a[1].count).slice(0, 10);
const heroPath = `/products/${heroProduct.id}/`;
const heroInquiry = productInquiryHref(heroProduct.data.title, heroProduct.data.sku, heroPath);
const collectionPreview = topCollections.slice(0, 6);
---

<BaseLayout title="Mirck | Richard Mille Private Catalogue" className="home-page">
	<main>
		<section class="home-hero" aria-labelledby="hero-title">
			<div class="home-hero__copy">
				<p class="kicker">{site.tagline}</p>
				<h1 id="hero-title" class="display-title">Private Richard Mille catalogue</h1>
				<p class="lead">
					A quieter commercial catalogue for collectors who want to compare references, open galleries, and send a direct inquiry with the exact product link attached.
				</p>
				<div class="button-row">
					<a class="button" href="/products/">Browse catalogue</a>
					<a class="button button--ghost" href="#collections">Shop by collection</a>
					<a class="button button--whatsapp" href={heroInquiry}>Ask on WhatsApp</a>
				</div>
			</div>

			<a class="home-hero__product" href={heroPath} aria-label={`Open ${heroProduct.data.title}`}>
				<img src={heroProduct.data.image} alt={heroProduct.data.title} loading="eager" />
				<span class="home-hero__tag">
					<small>{collectionName(heroProduct.data.category)}</small>
					<strong>{heroProduct.data.title}</strong>
				</span>
			</a>

			<div class="home-hero__stats" aria-label="Catalogue statistics">
				<div><strong>{products.length.toLocaleString('en-US')}</strong><span>Products</span></div>
				<div><strong>{collectionCounts.size}</strong><span>Families</span></div>
				<div><strong>WA</strong><span>Inquiry</span></div>
			</div>
		</section>

		<section id="collections" class="page-shell collection-showcase" aria-labelledby="collections-title">
			<div class="section-head">
				<div>
					<p class="kicker">Shop by family</p>
					<h2 id="collections-title">Collections first, products second.</h2>
				</div>
				<p>Most buyers already know the RM family they want. The site now puts those collection paths ahead of decorative blocks.</p>
			</div>

			<div class="collection-showcase__grid">
				{
					collectionPreview.map(([name, data]) => (
						<a class="collection-card" href={data.path}>
							<span class="collection-card__meta">
								<strong>{name}</strong>
								<small>{data.count.toLocaleString('en-US')} pieces</small>
							</span>
							{data.sample?.data.image && <img src={data.sample.data.image} alt={name} loading="lazy" />}
						</a>
					))
				}
			</div>
		</section>

		<section class="page-shell commerce-strip" aria-label="Client service">
			<div>
				<strong>Reference-led inquiry</strong>
				<span>Every detail page sends the product title, SKU, and canonical link to WhatsApp.</span>
			</div>
			<div>
				<strong>Private availability</strong>
				<span>Clients can request photos, batch details, and timing before ordering.</span>
			</div>
			<div>
				<strong>Clean browsing</strong>
				<span>Products are grouped by collection with a restrained, image-first catalogue layout.</span>
			</div>
		</section>

		<section class="page-shell">
			<div class="section-head">
				<div>
					<p class="kicker">Selected references</p>
					<h2>Quiet presentation, faster scanning.</h2>
				</div>
				<p>Product cards keep the watch visible and move long titles into a controlled information area below the image.</p>
			</div>
			<div class="product-grid">
				{featuredProducts.map((product, index) => <ProductCard product={product} priority={index < 4} />)}
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.home-hero {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 0.88fr) minmax(420px, 0.9fr);
		gap: clamp(32px, 5vw, 88px);
		align-items: start;
		width: min(var(--max), 100%);
		margin: 0 auto;
		padding: clamp(34px, 5vw, 64px) 40px 34px;
	}

	.home-hero__copy {
		display: grid;
		gap: 22px;
		align-content: center;
		padding-top: clamp(24px, 5vw, 58px);
	}

	.home-hero__copy .display-title {
		max-width: 780px;
	}

	.home-hero__product {
		position: relative;
		display: grid;
		place-items: center;
		min-height: min(560px, calc(100svh - 140px));
		border: 1px solid rgba(18, 18, 18, 0.1);
		background:
			radial-gradient(circle at 50% 24%, rgba(255, 255, 255, 0.96), rgba(236, 232, 222, 0.78) 58%, rgba(214, 209, 199, 0.72)),
			var(--panel);
		overflow: hidden;
	}

	.home-hero__product img {
		width: min(88%, 560px);
		max-height: 540px;
		object-fit: contain;
		filter: drop-shadow(0 34px 36px rgba(0, 0, 0, 0.2));
		transition: transform 260ms ease;
	}

	.home-hero__product:hover img {
		transform: translateY(-5px) scale(1.02);
	}

	.home-hero__tag {
		position: absolute;
		left: 22px;
		right: 22px;
		bottom: 22px;
		display: grid;
		gap: 6px;
		padding: 16px 18px;
		background: rgba(247, 245, 239, 0.86);
		backdrop-filter: blur(16px);
	}

	.home-hero__tag small,
	.home-hero__tag em {
		color: var(--muted);
		font-size: 0.7rem;
		font-style: normal;
		font-weight: 800;
		text-transform: uppercase;
	}

	.home-hero__tag strong {
		font-size: clamp(1rem, 1.4vw, 1.25rem);
		font-weight: 700;
		line-height: 1.22;
	}

	.home-hero__stats {
		grid-column: 1 / -1;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		border-top: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
	}

	.home-hero__stats div {
		display: grid;
		gap: 4px;
		padding: 18px 0;
		border-right: 1px solid var(--line);
	}

	.home-hero__stats div:last-child {
		border-right: 0;
	}

	.home-hero__stats strong {
		font-family: "Playfair Display", Georgia, serif;
		font-size: clamp(1.8rem, 3.2vw, 3.1rem);
		font-weight: 600;
		line-height: 1;
	}

	.home-hero__stats span {
		color: var(--muted);
		font-size: 0.72rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.collection-showcase__grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
	}

	.collection-card {
		position: relative;
		display: grid;
		align-items: end;
		min-height: 330px;
		border: 1px solid rgba(18, 18, 18, 0.09);
		background: rgba(255, 255, 255, 0.54);
		overflow: hidden;
	}

	.collection-card img {
		position: absolute;
		inset: 22px 18px 66px;
		width: calc(100% - 36px);
		height: calc(100% - 96px);
		object-fit: contain;
		filter: drop-shadow(0 24px 26px rgba(0, 0, 0, 0.14));
		transition: transform 240ms ease;
	}

	.collection-card:hover img {
		transform: translateY(-5px) scale(1.025);
	}

	.collection-card__meta {
		position: relative;
		z-index: 1;
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 18px;
		padding: 20px;
		background: linear-gradient(180deg, rgba(247, 245, 239, 0.72), rgba(247, 245, 239, 0.96));
	}

	.collection-card__meta strong {
		font-family: "Playfair Display", Georgia, serif;
		font-size: clamp(1.45rem, 2.3vw, 2.3rem);
		font-weight: 600;
		line-height: 1;
	}

	.collection-card__meta small {
		flex: 0 0 auto;
		color: var(--red);
		font-size: 0.7rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.commerce-strip {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 18px;
		margin-top: clamp(58px, 7vw, 92px);
	}

	.commerce-strip div {
		display: grid;
		gap: 10px;
		min-height: 138px;
		border-top: 1px solid var(--ink);
		padding-top: 18px;
	}

	.commerce-strip strong {
		font-size: 1.05rem;
		font-weight: 800;
	}

	.commerce-strip span {
		color: var(--muted);
		line-height: 1.62;
	}

	@media (max-width: 900px) {
		.home-hero {
			grid-template-columns: 1fr;
			padding: 34px 18px 24px;
		}

		.home-hero__product {
			min-height: 480px;
		}

		.collection-showcase__grid,
		.commerce-strip {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.home-hero__product {
			min-height: 430px;
		}

		.home-hero__stats,
		.collection-showcase__grid,
		.commerce-strip {
			grid-template-columns: 1fr;
		}

		.home-hero__stats div {
			border-right: 0;
			border-bottom: 1px solid var(--line);
		}
	}
</style>
