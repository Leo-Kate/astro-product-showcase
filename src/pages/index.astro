---
import { getCollection } from 'astro:content';

const products = await getCollection('products');
const featuredProducts = products.sort((a, b) => a.data.title.localeCompare(b.data.title));
const productCountLabel = `${featuredProducts.length} ${
	featuredProducts.length === 1 ? 'product' : 'products'
}`;

const formatPrice = (price: number) =>
	new Intl.NumberFormat('en-US', {
		style: 'currency',
		currency: 'USD',
		maximumFractionDigits: 0,
	}).format(price);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Product Showcase</title>
		<meta
			name="description"
			content="A fast Astro product showcase powered by Content Collections and Sveltia CMS."
		/>
		<style>
			:root {
				color: #17211d;
				background: #f7f4ee;
				font-family:
					Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				font-size: 16px;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				background:
					linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(247, 244, 238, 0.95)),
					#f7f4ee;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			.site-header,
			main {
				width: min(1120px, calc(100% - 32px));
				margin: 0 auto;
			}

			.site-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 24px;
				padding: 24px 0;
			}

			.brand-mark {
				font-size: 0.95rem;
				font-weight: 800;
				letter-spacing: 0;
			}

			.admin-link {
				border: 1px solid #1f2e2a;
				border-radius: 6px;
				padding: 10px 14px;
				font-size: 0.9rem;
				font-weight: 700;
			}

			.hero {
				display: grid;
				grid-template-columns: minmax(0, 0.95fr) minmax(280px, 1.05fr);
				gap: 48px;
				align-items: center;
				padding: 46px 0 58px;
			}

			.hero h1 {
				margin: 0;
				max-width: 760px;
				font-size: clamp(2.8rem, 7vw, 5.8rem);
				line-height: 0.92;
				font-weight: 850;
			}

			.hero p {
				margin: 22px 0 0;
				max-width: 560px;
				color: #52605b;
				font-size: 1.1rem;
				line-height: 1.7;
			}

			.hero-media {
				min-height: 420px;
				border-radius: 8px;
				background:
					linear-gradient(135deg, rgba(216, 229, 219, 0.45), rgba(255, 255, 255, 0.25)),
					#e3ddd2;
				display: grid;
				place-items: center;
				overflow: hidden;
			}

			.hero-media img {
				width: min(82%, 520px);
				height: auto;
				display: block;
				filter: drop-shadow(0 28px 34px rgba(25, 33, 30, 0.2));
			}

			.section-heading {
				display: flex;
				align-items: end;
				justify-content: space-between;
				gap: 20px;
				border-top: 1px solid rgba(31, 46, 42, 0.18);
				padding-top: 28px;
				margin-bottom: 22px;
			}

			.section-heading h2 {
				margin: 0;
				font-size: clamp(1.55rem, 3vw, 2.35rem);
			}

			.section-heading span {
				color: #68746f;
				font-size: 0.95rem;
			}

			.product-grid {
				display: grid;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				gap: 18px;
				padding-bottom: 56px;
			}

			.product-card {
				display: grid;
				grid-template-rows: auto 1fr;
				border: 1px solid rgba(31, 46, 42, 0.14);
				border-radius: 8px;
				background: rgba(255, 255, 255, 0.7);
				overflow: hidden;
			}

			.product-card img {
				width: 100%;
				aspect-ratio: 4 / 3;
				object-fit: cover;
				background: #e6ece8;
			}

			.product-card__body {
				display: grid;
				gap: 12px;
				padding: 18px;
			}

			.product-card__brand {
				color: #68746f;
				font-size: 0.82rem;
				font-weight: 800;
				text-transform: uppercase;
			}

			.product-card h3 {
				margin: 0;
				font-size: 1.2rem;
				line-height: 1.25;
			}

			.product-card__meta {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 12px;
				margin-top: auto;
				font-weight: 800;
			}

			.stock {
				color: #1f6f4a;
				font-size: 0.86rem;
			}

			.stock[data-empty="true"] {
				color: #8d3d33;
			}

			@media (max-width: 840px) {
				.hero {
					grid-template-columns: 1fr;
					gap: 28px;
					padding-top: 26px;
				}

				.hero-media {
					min-height: 300px;
				}

				.product-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}
			}

			@media (max-width: 560px) {
				.site-header {
					align-items: flex-start;
					flex-direction: column;
				}

				.product-grid {
					grid-template-columns: 1fr;
				}

				.section-heading {
					align-items: flex-start;
					flex-direction: column;
				}
			}
		</style>
	</head>
	<body>
		<header class="site-header">
			<a class="brand-mark" href="/">Product Showcase</a>
			<a class="admin-link" href="/admin/index.html">CMS Admin</a>
		</header>

		<main>
			<section class="hero" aria-labelledby="hero-title">
				<div>
					<h1 id="hero-title">Curated products, managed from Git.</h1>
					<p>
						This Astro storefront uses typed Content Collections for product data and Sveltia CMS
						for a clean Git-based editing workflow.
					</p>
				</div>
				<div class="hero-media">
					<img src="/images/uploads/atlas-modular-pack.svg" alt="Atlas Modular Pack" />
				</div>
			</section>

			<section aria-labelledby="products-title">
				<div class="section-heading">
					<h2 id="products-title">Featured products</h2>
					<span>{productCountLabel}</span>
				</div>

				<div class="product-grid">
					{
						featuredProducts.map((product) => (
							<a class="product-card" href={`/products/${product.id}/`}>
								<img src={product.data.image} alt={product.data.title} />
								<div class="product-card__body">
									<span class="product-card__brand">{product.data.brand}</span>
									<h3>{product.data.title}</h3>
									<div class="product-card__meta">
										<span>{formatPrice(product.data.price)}</span>
										<span class="stock" data-empty={!product.data.in_stock}>
											{product.data.in_stock ? 'In stock' : 'Out of stock'}
										</span>
									</div>
								</div>
							</a>
						))
					}
				</div>
			</section>
		</main>
	</body>
</html>
