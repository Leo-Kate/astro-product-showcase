---
import { getCollection } from 'astro:content';
import BaseLayout from '../components/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import { collectionName, collectionPath, isAccessoryProduct, priceLabel, productInquiryHref, site } from '../lib/catalog';

const products = (await getCollection('products')).sort((a, b) => a.data.title.localeCompare(b.data.title));
const heroProduct =
	products.find((product) => product.data.sku === 'PMS011') ??
	products.find((product) => {
		const title = product.data.title.toLowerCase();
		return product.data.image && product.data.category?.includes('RM 011') && !title.includes('screw') && !title.includes('box');
	}) ?? products.find((product) => product.data.image) ?? products[0];

const featuredProducts = products
	.filter((product) => {
		const title = product.data.title.toLowerCase();
		return product.data.image && !isAccessoryProduct(product) && !title.includes('strap for');
	})
	.slice(0, 12);

const collectionCounts = products.reduce<Map<string, { count: number; path: string }>>((counts, product) => {
	const name = collectionName(product.data.category);
	const current = counts.get(name) ?? { count: 0, path: collectionPath(product.data.category) };
	current.count += 1;
	counts.set(name, current);
	return counts;
}, new Map());

const topCollections = [...collectionCounts.entries()].sort((a, b) => b[1].count - a[1].count).slice(0, 12);
const heroPath = `/products/${heroProduct.id}/`;
const heroInquiry = productInquiryHref(heroProduct.data.title, heroProduct.data.sku, heroPath);
const storyProducts = featuredProducts.slice(1, 5);
---

<BaseLayout title="Mirck | Richard Mille Private Catalogue" className="home-page">
	<main>
		<section class="home-hero" aria-labelledby="hero-title">
			<div class="home-hero__copy">
				<p class="kicker">{site.tagline}</p>
				<h1 id="hero-title" class="display-title">Richard Mille catalogue for private client selection.</h1>
				<p class="lead">
					A focused product showcase for RM references, organized by collection and built around direct inquiry.
				</p>
				<div class="button-row">
					<a class="button" href="/products/">View Catalogue</a>
					<a class="button button--ghost" href="#collections">Browse Collections</a>
					<a class="button button--whatsapp" href={heroInquiry}>WhatsApp This Piece</a>
				</div>
			</div>
			<a class="home-hero__watch" href={heroPath} aria-label={`Open ${heroProduct.data.title}`}>
				<img src={heroProduct.data.image} alt={heroProduct.data.title} loading="eager" />
			</a>
			<div class="home-hero__caption">
				<span>{collectionName(heroProduct.data.category)}</span>
				<strong>{heroProduct.data.title}</strong>
				<small>{priceLabel(heroProduct.data.price)}</small>
			</div>
		</section>

		<section class="page-shell stats-strip" aria-label="Catalogue statistics">
			<div><strong>{products.length.toLocaleString('en-US')}</strong><span>Richard Mille products</span></div>
			<div><strong>{collectionCounts.size}</strong><span>Collections and families</span></div>
			<div><strong>WhatsApp</strong><span>Direct private inquiry</span></div>
		</section>

		<section class="page-shell editorial-section" aria-labelledby="editorial-title">
			<div class="section-head">
				<h2 id="editorial-title">A private RM universe.</h2>
				<p>Large imagery, focused collection paths, and product-specific WhatsApp links keep the buying conversation fast.</p>
			</div>
			<div class="editorial-grid">
				{
					storyProducts.map((product, index) => (
						<a class:list={['editorial-tile', index === 0 && 'editorial-tile--wide']} href={`/products/${product.id}/`}>
							<img src={product.data.image} alt={product.data.title} loading="lazy" />
							<span>{collectionName(product.data.category)}</span>
							<strong>{product.data.title}</strong>
						</a>
					))
				}
			</div>
		</section>

		<section id="collections" class="page-shell">
			<div class="section-head">
				<h2>Browse by collection.</h2>
				<p>Use the strongest RM families as the starting point, then open any reference for gallery and inquiry.</p>
			</div>
			<div class="collection-index">
				{
					topCollections.map(([name, data], index) => (
						<a href={data.path}>
							<span>{String(index + 1).padStart(2, '0')}</span>
							<strong>{name}</strong>
							<small>{data.count.toLocaleString('en-US')} pieces</small>
						</a>
					))
				}
			</div>
		</section>

		<section class="client-desk" aria-labelledby="desk-title">
			<div class="page-shell client-desk__inner">
				<div>
					<p class="kicker">Client Desk</p>
					<h2 id="desk-title">Built for detail-driven buyers.</h2>
				</div>
				<div class="client-desk__items">
					<div><strong>Free worldwide shipping</strong><span>Commercial positioning aligned with Mirckclone's main store promise.</span></div>
					<div><strong>Private availability check</strong><span>Send any reference through WhatsApp and keep the product link attached.</span></div>
					<div><strong>Photo request workflow</strong><span>Ask for more angles, batch details, and payment timing before purchase.</span></div>
					<div><strong>Collection-led browsing</strong><span>RM 011, RM 055, RM 35-02, RM 052 and other families stay one tap away.</span></div>
				</div>
			</div>
		</section>

		<section class="page-shell">
			<div class="section-head">
				<h2>Selected references.</h2>
				<p>Clean product tiles keep the watch visible first, with model family, SKU and inquiry price below.</p>
			</div>
			<div class="product-grid">
				{featuredProducts.map((product, index) => <ProductCard product={product} priority={index < 4} />)}
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.home-hero {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 0.94fr) minmax(360px, 0.72fr);
		align-items: center;
		min-height: calc(100svh - 73px);
		padding: clamp(40px, 7vw, 94px) clamp(18px, 4vw, 54px) clamp(74px, 10vw, 128px);
		background:
			linear-gradient(90deg, rgba(245, 243, 239, 0.96) 0%, rgba(245, 243, 239, 0.78) 48%, rgba(245, 243, 239, 0.42) 100%),
			linear-gradient(180deg, #ffffff, #e7e2d8);
		overflow: hidden;
	}

	.home-hero::after {
		position: absolute;
		right: 0;
		bottom: 0;
		width: 42%;
		height: 1px;
		background: var(--ink);
		content: "";
	}

	.home-hero__copy {
		position: relative;
		z-index: 2;
		display: grid;
		gap: 28px;
		max-width: 980px;
	}

	.home-hero__copy .lead {
		max-width: 560px;
	}

	.home-hero__watch {
		position: relative;
		z-index: 1;
		display: grid;
		place-items: center;
		min-height: 520px;
	}

	.home-hero__watch img {
		width: min(100%, 560px);
		max-height: 74vh;
		object-fit: contain;
		filter: drop-shadow(0 34px 40px rgba(0, 0, 0, 0.24));
	}

	.home-hero__caption {
		position: absolute;
		right: clamp(18px, 4vw, 54px);
		bottom: clamp(96px, 8vw, 126px);
		z-index: 3;
		display: grid;
		gap: 6px;
		width: min(360px, calc(100% - 36px));
		border-left: 2px solid var(--red);
		padding-left: 18px;
	}

	.home-hero__caption span,
	.home-hero__caption small {
		color: var(--muted);
		font-size: 0.74rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.home-hero__caption strong {
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(1.15rem, 1.8vw, 1.7rem);
		font-weight: 400;
		line-height: 1.1;
	}

	.stats-strip {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		border-top: 1px solid var(--ink);
		border-bottom: 1px solid var(--line);
	}

	.stats-strip div {
		display: grid;
		gap: 8px;
		padding: 24px 0;
		border-right: 1px solid var(--line);
	}

	.stats-strip div:last-child {
		border-right: 0;
		padding-left: clamp(0px, 2vw, 22px);
	}

	.stats-strip strong {
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(1.75rem, 3vw, 3rem);
		font-weight: 400;
	}

	.stats-strip span {
		color: var(--muted);
		font-size: 0.78rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.collection-index {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		border-top: 1px solid var(--line);
		border-left: 1px solid var(--line);
	}

	.collection-index a {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 8px 18px;
		min-height: 128px;
		border-right: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		padding: clamp(18px, 2.4vw, 30px);
		background: var(--paper);
	}

	.collection-index a:hover {
		background: var(--white);
	}

	.collection-index span {
		color: var(--red);
		font-size: 0.72rem;
		font-weight: 900;
	}

	.collection-index strong {
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(1.3rem, 2.2vw, 2rem);
		font-weight: 400;
		line-height: 1.05;
	}

	.collection-index small {
		grid-column: 2;
		color: var(--muted);
		font-size: 0.78rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.editorial-section {
		padding-bottom: clamp(26px, 5vw, 72px);
	}

	.editorial-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		border-top: 1px solid var(--line);
		border-left: 1px solid var(--line);
	}

	.editorial-tile {
		position: relative;
		display: grid;
		align-content: end;
		min-height: clamp(360px, 42vw, 620px);
		border-right: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		padding: clamp(18px, 2.4vw, 32px);
		background: #0b0b0c;
		color: var(--white);
		overflow: hidden;
	}

	.editorial-tile--wide {
		grid-column: span 2;
	}

	.editorial-tile img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: contain;
		padding: clamp(24px, 5vw, 64px);
		opacity: 0.82;
		transition: transform 260ms ease, opacity 260ms ease;
	}

	.editorial-tile::after {
		position: absolute;
		inset: 0;
		background: linear-gradient(180deg, transparent 30%, rgba(0, 0, 0, 0.76));
		content: "";
	}

	.editorial-tile:hover img {
		opacity: 1;
		transform: scale(1.04);
	}

	.editorial-tile span,
	.editorial-tile strong {
		position: relative;
		z-index: 1;
	}

	.editorial-tile span {
		margin-bottom: 10px;
		color: #ff3848;
		font-size: 0.72rem;
		font-weight: 900;
		text-transform: uppercase;
	}

	.editorial-tile strong {
		max-width: 520px;
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(1.4rem, 2.7vw, 3.6rem);
		font-weight: 400;
		line-height: 1;
	}

	.client-desk {
		margin-top: clamp(48px, 8vw, 96px);
		background: var(--black);
		color: var(--white);
	}

	.client-desk__inner {
		display: grid;
		grid-template-columns: minmax(0, 0.72fr) minmax(0, 1fr);
		gap: clamp(26px, 6vw, 90px);
		padding-top: clamp(54px, 8vw, 110px);
		padding-bottom: clamp(54px, 8vw, 110px);
	}

	.client-desk h2 {
		margin: 0;
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(2.6rem, 5.8vw, 6.6rem);
		font-weight: 400;
		line-height: 0.95;
	}

	.client-desk__items {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		border-top: 1px solid rgba(255, 255, 255, 0.22);
		border-left: 1px solid rgba(255, 255, 255, 0.22);
	}

	.client-desk__items div {
		display: grid;
		gap: 12px;
		min-height: 150px;
		border-right: 1px solid rgba(255, 255, 255, 0.22);
		border-bottom: 1px solid rgba(255, 255, 255, 0.22);
		padding: clamp(18px, 2.4vw, 28px);
	}

	.client-desk__items strong {
		font-family: Georgia, "Times New Roman", serif;
		font-size: clamp(1.22rem, 2vw, 1.8rem);
		font-weight: 400;
		line-height: 1.1;
	}

	.client-desk__items span {
		color: rgba(255, 255, 255, 0.68);
		line-height: 1.62;
	}

	@media (max-width: 900px) {
		.home-hero {
			grid-template-columns: 1fr;
			min-height: auto;
			padding-bottom: 148px;
		}

		.home-hero__watch {
			min-height: 360px;
		}

		.collection-index {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.editorial-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.client-desk__inner {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 620px) {
		.home-hero {
			padding-top: 34px;
		}

		.home-hero__caption {
			left: 18px;
			right: 18px;
			bottom: 72px;
		}

		.stats-strip,
		.collection-index,
		.editorial-grid,
		.client-desk__items {
			grid-template-columns: 1fr;
		}

		.editorial-tile--wide {
			grid-column: auto;
		}

		.stats-strip div {
			border-right: 0;
			border-bottom: 1px solid var(--line);
		}
	}
</style>
