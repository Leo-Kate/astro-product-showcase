---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { collectionName, compareProductsForDisplay, slugify } from '../../lib/catalog';

export async function getStaticPaths() {
	const products = await getCollection('products');
	const groups = new Map<string, typeof products>();

	for (const product of products) {
		const key = slugify(collectionName(product.data.category));
		groups.set(key, [...(groups.get(key) ?? []), product]);
	}

	return [...groups.entries()].map(([collection, items]) => ({
		params: { collection },
		props: {
			name: collectionName(items[0]?.data.category),
			products: items.sort(compareProductsForDisplay),
		},
	}));
}

const { name, products } = Astro.props;
const heroProduct = products.find((product) => product.data.image) ?? products[0];
---

<BaseLayout title={`${name} | Mirck`} description={`Browse ${name} references in the Mirck Richard Mille catalogue.`}>
	<main>
		<section class="collection-hero" aria-labelledby="collection-title">
			<div class="collection-hero__copy">
				<p class="kicker">Collection</p>
				<h1 id="collection-title" class="display-title">{name}</h1>
				<p class="lead">
					{products.length.toLocaleString('en-US')} products in this family, arranged as a clean commercial grid for quick comparison and inquiry.
				</p>
				<div class="button-row">
					<a class="button" href="/products/">Full Catalogue</a>
					<a class="button button--ghost" href="#collection-products">View References</a>
				</div>
			</div>
			{heroProduct && (
				<a class="collection-hero__image" href={`/products/${heroProduct.id}/`}>
					<img src={heroProduct.data.image} alt={heroProduct.data.title} loading="eager" />
				</a>
			)}
		</section>

		<section id="collection-products" class="page-shell collection-products">
			<div class="section-head">
				<h2>{name} references</h2>
				<p>Open a product page for gallery images, SKU, availability, and WhatsApp inquiry with product link.</p>
			</div>
			<div class="collection-tools" role="search">
				<label for="collection-search">Search this collection</label>
				<input id="collection-search" type="search" placeholder={`Search ${name}, SKU, or title`} autocomplete="off" />
				<span id="collection-count">{products.length.toLocaleString('en-US')} products</span>
			</div>
			<div class="product-grid">
				{products.map((product, index) => <ProductCard product={product} priority={index < 8} />)}
			</div>
		</section>
	</main>
</BaseLayout>

<script>
	const searchInput = document.querySelector<HTMLInputElement>('#collection-search');
	const countNode = document.querySelector<HTMLElement>('#collection-count');
	const productCards = [...document.querySelectorAll<HTMLElement>('[data-product-card]')];

	function updateCollectionFilter() {
		const query = searchInput?.value.trim().toLowerCase() ?? '';
		let visible = 0;

		for (const card of productCards) {
			const haystack = [card.dataset.title, card.dataset.collection, card.dataset.sku].filter(Boolean).join(' ').toLowerCase();
			const match = !query || haystack.includes(query);
			card.hidden = !match;
			if (match) visible += 1;
		}

		if (countNode) countNode.textContent = `${visible.toLocaleString('en-US')} products`;
	}

	searchInput?.addEventListener('input', updateCollectionFilter);
</script>

<style>
	.collection-hero {
		display: grid;
		grid-template-columns: minmax(0, 0.86fr) minmax(320px, 0.58fr);
		gap: clamp(34px, 6vw, 84px);
		align-items: center;
		width: min(var(--max), 100%);
		margin: 0 auto;
		padding: clamp(42px, 7vw, 84px) 40px;
		border-bottom: 1px solid var(--line);
	}

	.collection-hero__copy {
		display: grid;
		gap: 26px;
	}

	.collection-hero__copy .lead {
		max-width: 600px;
	}

	.collection-hero__image {
		display: grid;
		place-items: center;
		min-height: 430px;
		border: 1px solid rgba(18, 18, 18, 0.09);
		background:
			radial-gradient(circle at 50% 24%, rgba(255, 255, 255, 0.96), rgba(236, 232, 222, 0.75) 58%, rgba(214, 209, 199, 0.7)),
			var(--panel);
	}

	.collection-hero__image img {
		width: min(84%, 460px);
		max-height: 560px;
		object-fit: contain;
		filter: drop-shadow(0 28px 30px rgba(0, 0, 0, 0.18));
	}

	.collection-products {
		padding-bottom: 96px;
	}

	.collection-tools {
		display: grid;
		grid-template-columns: auto minmax(260px, 1fr) auto;
		gap: 14px;
		align-items: center;
		margin-bottom: 24px;
		border: 1px solid var(--line);
		padding: 12px 14px;
		background: rgba(255, 255, 255, 0.7);
	}

	.collection-tools label,
	.collection-tools span {
		color: var(--muted);
		font-size: 0.72rem;
		font-weight: 800;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.collection-tools input {
		width: 100%;
		min-height: 42px;
		border: 1px solid rgba(18, 18, 18, 0.15);
		border-radius: 999px;
		padding: 0 16px;
		background: var(--white);
		color: var(--ink);
		font: inherit;
	}

	.collection-tools input:focus {
		border-color: var(--red);
		outline: 0;
	}

	@media (max-width: 840px) {
		.collection-hero {
			grid-template-columns: 1fr;
			gap: 26px;
			min-height: auto;
			padding: 42px 18px;
		}

		.collection-hero__image {
			min-height: 340px;
		}

		.collection-tools {
			grid-template-columns: 1fr;
			gap: 8px;
		}
	}
</style>
