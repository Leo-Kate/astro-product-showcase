---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const products = await getCollection('products');

	return products.map((product) => ({
		params: { slug: product.id },
		props: { product },
	}));
}

const { product } = Astro.props;
const { Content } = await render(product);
const gallery = product.data.images?.length ? product.data.images.slice(0, 8) : [product.data.image];

const price = typeof product.data.price === 'number'
	? new Intl.NumberFormat('en-US', {
			style: 'currency',
			currency: 'USD',
			maximumFractionDigits: 0,
		}).format(product.data.price)
	: 'Price on request';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{product.data.title} | Mirck</title>
		<meta name="description" content={product.data.excerpt ?? `${product.data.brand} ${product.data.title}`} />
		<style>
			:root {
				color: #f4efe5;
				background: #090b0d;
				font-family:
					Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				font-size: 16px;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				background:
					radial-gradient(circle at 12% 0%, rgba(178, 134, 72, 0.18), transparent 32%),
					#090b0d;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			img {
				display: block;
			}

			.site-header,
			main {
				width: min(1240px, calc(100% - 32px));
				margin: 0 auto;
			}

			.site-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 24px;
				padding: 24px 0;
			}

			.brand-mark,
			.back-link {
				font-size: 0.95rem;
				font-weight: 850;
				letter-spacing: 0.1em;
				text-transform: uppercase;
			}

			.back-link {
				color: #d9d1c2;
			}

			.product {
				display: grid;
				grid-template-columns: minmax(320px, 1.06fr) minmax(0, 0.94fr);
				gap: 54px;
				align-items: start;
				padding: 42px 0 80px;
			}

			.product-media {
				display: grid;
				gap: 14px;
			}

			.main-image {
				border: 1px solid rgba(244, 239, 229, 0.13);
				border-radius: 8px;
				background: #151719;
				overflow: hidden;
			}

			.main-image img {
				width: 100%;
				aspect-ratio: 1 / 1;
				object-fit: cover;
			}

			.gallery {
				display: grid;
				grid-template-columns: repeat(4, minmax(0, 1fr));
				gap: 10px;
			}

			.gallery img {
				width: 100%;
				aspect-ratio: 1 / 1;
				object-fit: cover;
				border: 1px solid rgba(244, 239, 229, 0.12);
				border-radius: 7px;
				background: #151719;
			}

			.product-info {
				position: sticky;
				top: 22px;
			}

			.eyebrow {
				margin: 0 0 12px;
				color: #c89b5a;
				font-size: 0.78rem;
				font-weight: 850;
				letter-spacing: 0.16em;
				text-transform: uppercase;
			}

			h1 {
				margin: 0;
				font-size: clamp(2.35rem, 5vw, 5.1rem);
				line-height: 0.95;
			}

			.summary {
				margin: 22px 0 0;
				color: #c8c1b7;
				font-size: 1rem;
				line-height: 1.7;
			}

			.purchase-row {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 12px;
				margin: 28px 0;
			}

			.price,
			.stock,
			.meta-pill {
				border-radius: 7px;
				padding: 10px 12px;
				font-weight: 850;
			}

			.price {
				background: #d7a85e;
				color: #101010;
			}

			.stock,
			.meta-pill {
				border: 1px solid rgba(244, 239, 229, 0.14);
				color: #d9d1c2;
			}

			.stock[data-empty="true"] {
				color: #d99080;
			}

			.meta-grid {
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				gap: 10px;
				margin-bottom: 30px;
			}

			.meta-pill span {
				display: block;
				margin-bottom: 5px;
				color: #8e887f;
				font-size: 0.72rem;
				letter-spacing: 0.11em;
				text-transform: uppercase;
			}

			.description {
				border-top: 1px solid rgba(244, 239, 229, 0.12);
				padding-top: 28px;
				color: #d9d1c2;
				font-size: 1rem;
				line-height: 1.78;
			}

			.description :global(p) {
				margin: 0 0 18px;
			}

			.description :global(h2),
			.description :global(h3) {
				color: #f4efe5;
				margin: 30px 0 12px;
			}

			.description :global(ul) {
				padding-left: 1.2rem;
			}

			.description :global(li) {
				margin: 8px 0;
			}

			@media (max-width: 860px) {
				.product {
					grid-template-columns: 1fr;
					gap: 28px;
					padding-top: 20px;
				}

				.product-info {
					position: static;
				}
			}

			@media (max-width: 560px) {
				.site-header {
					align-items: flex-start;
					flex-direction: column;
				}

				.gallery,
				.meta-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}
			}
		</style>
	</head>
	<body>
		<header class="site-header">
			<a class="brand-mark" href="/">Mirck</a>
			<a class="back-link" href="/products/">Catalogue</a>
		</header>

		<main>
			<article class="product">
				<div class="product-media">
					<div class="main-image">
						<img src={product.data.image} alt={product.data.title} />
					</div>
					<div class="gallery" aria-label="Product gallery">
						{gallery.map((image) => <img src={image} alt={product.data.title} loading="lazy" />)}
					</div>
				</div>

				<div class="product-info">
					<p class="eyebrow">{product.data.brand}</p>
					<h1>{product.data.title}</h1>
					{product.data.excerpt && <p class="summary">{product.data.excerpt}</p>}
					<div class="purchase-row">
						<span class="price">{price}</span>
						<span class="stock" data-empty={!product.data.in_stock}>
							{product.data.in_stock ? 'Available' : 'Unavailable'}
						</span>
					</div>
					<div class="meta-grid">
						{product.data.sku && <div class="meta-pill"><span>SKU</span>{product.data.sku}</div>}
						{product.data.category && <div class="meta-pill"><span>Collection</span>{product.data.category}</div>}
					</div>
					<div class="description">
						<Content />
					</div>
				</div>
			</article>
		</main>
	</body>
</html>
