---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import { collectionName, collectionPath, priceLabel, productInquiryHref } from '../../lib/catalog';

export async function getStaticPaths() {
	const products = await getCollection('products');

	return products.map((product) => ({
		params: { slug: product.id },
		props: { product },
	}));
}

const { product } = Astro.props;
const { Content } = await render(product);
const gallery = product.data.images?.length ? product.data.images.slice(0, 8) : [product.data.image];
const collection = collectionName(product.data.category);
const productPath = `/products/${product.id}/`;
const askHref = productInquiryHref(product.data.title, product.data.sku, productPath);
---

<BaseLayout title={`${product.data.title} | Mirck`} description={product.data.excerpt ?? `${product.data.brand} ${product.data.title}`}>
	<main class="product-detail">
		<section class="product-detail__media" aria-label="Product gallery">
			<div class="product-detail__main-image">
				<img src={product.data.image} alt={product.data.title} loading="eager" />
			</div>
			<div class="product-detail__gallery">
				{gallery.map((image) => <img src={image} alt={product.data.title} loading="lazy" />)}
			</div>
		</section>

		<article class="product-detail__info">
			<a class="product-detail__collection" href={collectionPath(product.data.category)}>{collection}</a>
			<h1>{product.data.title}</h1>
			{product.data.excerpt && <p class="product-detail__summary">{product.data.excerpt}</p>}

			<div class="product-detail__commerce">
				<span>{priceLabel(product.data.price)}</span>
				<strong>{product.data.in_stock ? 'Available' : 'Unavailable'}</strong>
			</div>

			<div class="product-detail__actions">
				<a class="button button--whatsapp" href={askHref}>WhatsApp Inquiry</a>
				<a class="button" href={askHref}>Request Current Photos</a>
				<a class="button button--ghost" href="/products/">Back to Catalogue</a>
			</div>

			<div class="product-detail__facts">
				{product.data.sku && <div><span>SKU</span><strong>{product.data.sku}</strong></div>}
				<div><span>Brand</span><strong>{product.data.brand}</strong></div>
				<div><span>Collection</span><strong>{collection}</strong></div>
			</div>

			<section class="product-detail__description" aria-label="Product description">
				<Content />
			</section>
		</article>
	</main>
</BaseLayout>

<style>
	.product-detail {
		display: grid;
		grid-template-columns: minmax(0, 1.08fr) minmax(380px, 0.62fr);
		gap: clamp(34px, 5vw, 70px);
		width: min(var(--max), 100%);
		margin: 0 auto;
		padding: 44px;
	}

	.product-detail__media {
		display: grid;
		gap: 14px;
		align-self: start;
	}

	.product-detail__main-image {
		display: grid;
		place-items: center;
		min-height: min(780px, calc(100svh - 130px));
		border: 1px solid rgba(18, 18, 18, 0.1);
		background:
			radial-gradient(circle at 50% 24%, rgba(255, 255, 255, 0.96), rgba(236, 232, 222, 0.76) 58%, rgba(214, 209, 199, 0.7)),
			var(--panel);
		overflow: hidden;
	}

	.product-detail__main-image img {
		width: min(100%, 760px);
		height: min(72vh, 720px);
		object-fit: contain;
		padding: 58px;
		filter: drop-shadow(0 30px 38px rgba(0, 0, 0, 0.24));
	}

	.product-detail__gallery {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		border-top: 1px solid var(--line);
		border-left: 1px solid var(--line);
	}

	.product-detail__gallery img {
		width: 100%;
		aspect-ratio: 1 / 1;
		object-fit: contain;
		border-right: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		padding: 12px;
		background: #f8f7f4;
	}

	.product-detail__info {
		position: sticky;
		top: 98px;
		align-self: start;
		display: grid;
		gap: 22px;
		padding-top: 2px;
	}

	.product-detail__collection {
		width: fit-content;
		color: var(--red);
		font-size: 0.76rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.product-detail h1 {
		margin: 0;
		font-family: "Playfair Display", Georgia, serif;
		font-size: clamp(2.25rem, 3.9vw, 4.25rem);
		font-weight: 600;
		line-height: 1;
	}

	.product-detail__summary {
		margin: 0;
		color: var(--muted);
		font-size: 1rem;
		line-height: 1.75;
	}

	.product-detail__commerce {
		display: grid;
		grid-template-columns: 1fr 1fr;
		border-top: 1px solid var(--ink);
		border-bottom: 1px solid var(--line);
	}

	.product-detail__commerce span,
	.product-detail__commerce strong {
		padding: 18px 0;
		font-size: 0.86rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.product-detail__commerce strong {
		color: var(--red);
		text-align: right;
	}

	.product-detail__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
	}

	.product-detail__facts {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		border-top: 1px solid var(--line);
		border-left: 1px solid var(--line);
	}

	.product-detail__facts div {
		display: grid;
		gap: 8px;
		min-width: 0;
		border-right: 1px solid var(--line);
		border-bottom: 1px solid var(--line);
		padding: 16px;
	}

	.product-detail__facts span {
		color: var(--muted);
		font-size: 0.7rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.product-detail__facts strong {
		overflow-wrap: anywhere;
		font-size: 0.9rem;
		font-weight: 700;
		line-height: 1.35;
	}

	.product-detail__description {
		border-top: 1px solid var(--ink);
		padding-top: 24px;
		color: #333;
		font-size: 0.98rem;
		line-height: 1.78;
	}

	.product-detail__description :global(p) {
		margin: 0 0 18px;
	}

	.product-detail__description :global(ul) {
		margin: 0 0 18px;
		padding-left: 1.1rem;
	}

	.product-detail__description :global(li) {
		margin: 8px 0;
	}

	.product-detail__description :global(h2),
	.product-detail__description :global(h3) {
		margin: 28px 0 12px;
		font-family: "Playfair Display", Georgia, serif;
		font-weight: 600;
	}

	@media (max-width: 900px) {
		.product-detail {
			grid-template-columns: 1fr;
			gap: 30px;
			padding: 18px;
		}

		.product-detail__main-image {
			min-height: 440px;
		}

		.product-detail__main-image img {
			height: 420px;
			padding: 28px;
		}

		.product-detail__info {
			position: static;
		}

		.product-detail h1 {
			font-size: 2.55rem;
		}
	}

	@media (max-width: 560px) {
		.product-detail__gallery,
		.product-detail__facts {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.product-detail__commerce {
			grid-template-columns: 1fr;
		}

		.product-detail__commerce strong {
			text-align: left;
			border-top: 1px solid var(--line);
		}

		.product-detail h1 {
			font-size: 2.1rem;
		}
	}
</style>
