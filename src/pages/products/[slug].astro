---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
	const products = await getCollection('products');

	return products.map((product) => ({
		params: { slug: product.id },
		props: { product },
	}));
}

const { product } = Astro.props;
const { Content } = await render(product);

const price = new Intl.NumberFormat('en-US', {
	style: 'currency',
	currency: 'USD',
	maximumFractionDigits: 0,
}).format(product.data.price);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{product.data.title} | Product Showcase</title>
		<meta name="description" content={`${product.data.brand} ${product.data.title}`} />
		<style>
			:root {
				color: #17211d;
				background: #f7f4ee;
				font-family:
					Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				font-size: 16px;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				background: #f7f4ee;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			.site-header,
			main {
				width: min(1120px, calc(100% - 32px));
				margin: 0 auto;
			}

			.site-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 24px;
				padding: 24px 0;
			}

			.brand-mark,
			.back-link {
				font-size: 0.95rem;
				font-weight: 800;
			}

			.product {
				display: grid;
				grid-template-columns: minmax(280px, 1.05fr) minmax(0, 0.95fr);
				gap: 52px;
				align-items: start;
				padding: 38px 0 70px;
			}

			.product-media {
				border-radius: 8px;
				background:
					linear-gradient(135deg, rgba(216, 229, 219, 0.45), rgba(255, 255, 255, 0.28)),
					#e3ddd2;
				overflow: hidden;
			}

			.product-media img {
				display: block;
				width: 100%;
				aspect-ratio: 4 / 3;
				object-fit: cover;
			}

			.eyebrow {
				margin: 0 0 12px;
				color: #68746f;
				font-size: 0.82rem;
				font-weight: 800;
				text-transform: uppercase;
			}

			h1 {
				margin: 0;
				font-size: clamp(2.4rem, 5.4vw, 5rem);
				line-height: 0.96;
			}

			.purchase-row {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 18px;
				margin: 28px 0;
			}

			.price {
				font-size: 1.6rem;
				font-weight: 850;
			}

			.stock {
				border: 1px solid rgba(31, 111, 74, 0.35);
				border-radius: 6px;
				color: #1f6f4a;
				padding: 8px 11px;
				font-size: 0.9rem;
				font-weight: 800;
			}

			.stock[data-empty="true"] {
				border-color: rgba(141, 61, 51, 0.35);
				color: #8d3d33;
			}

			.description {
				color: #3a4742;
				font-size: 1.05rem;
				line-height: 1.75;
			}

			.description :global(h2) {
				margin: 32px 0 12px;
				color: #17211d;
				font-size: 1.35rem;
			}

			.description :global(ul) {
				padding-left: 1.2rem;
			}

			.description :global(li) {
				margin: 8px 0;
			}

			@media (max-width: 800px) {
				.product {
					grid-template-columns: 1fr;
					gap: 28px;
					padding-top: 22px;
				}
			}
		</style>
	</head>
	<body>
		<header class="site-header">
			<a class="brand-mark" href="/">Product Showcase</a>
			<a class="back-link" href="/">Back to products</a>
		</header>

		<main>
			<article class="product">
				<div class="product-media">
					<img src={product.data.image} alt={product.data.title} />
				</div>

				<div>
					<p class="eyebrow">{product.data.brand}</p>
					<h1>{product.data.title}</h1>
					<div class="purchase-row">
						<span class="price">{price}</span>
						<span class="stock" data-empty={!product.data.in_stock}>
							{product.data.in_stock ? 'In stock' : 'Out of stock'}
						</span>
					</div>
					<div class="description">
						<Content />
					</div>
				</div>
			</article>
		</main>
	</body>
</html>
