---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { collectionName, collectionPath, compareProductsForDisplay } from '../../lib/catalog';

const products = (await getCollection('products')).sort(compareProductsForDisplay);

const collectionCounts = products.reduce<Map<string, { count: number; path: string }>>((counts, product) => {
	const name = collectionName(product.data.category);
	const current = counts.get(name) ?? { count: 0, path: collectionPath(product.data.category) };
	current.count += 1;
	counts.set(name, current);
	return counts;
}, new Map());

const collections = [...collectionCounts.entries()].sort((a, b) => b[1].count - a[1].count || a[0].localeCompare(b[0]));
---

<BaseLayout title="Catalogue | Mirck" description="Browse the full Mirck Richard Mille catalogue by collection and reference.">
	<main class="page-shell catalogue-page">
		<section class="catalogue-hero" aria-labelledby="catalogue-title">
			<div>
				<p class="kicker">Full Catalogue</p>
				<h1 id="catalogue-title" class="display-title">{products.length.toLocaleString('en-US')} Richard Mille references.</h1>
			</div>
			<p class="lead">
				Every product from the new Richard Mille catalogue is available here. Use collection links for a tighter client presentation.
			</p>
		</section>

		<nav class="collection-rail" aria-label="Collection counts">
			{
				collections.map(([name, data]) => (
					<a href={data.path}>
						<span>{name}</span>
						<strong>{data.count}</strong>
					</a>
				))
			}
		</nav>

		<section class="product-grid" aria-label="Products">
			{products.map((product, index) => <ProductCard product={product} priority={index < 8} />)}
		</section>
	</main>
</BaseLayout>

<style>
	.catalogue-page {
		padding-bottom: 96px;
	}

	.catalogue-hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 430px);
		gap: clamp(24px, 5vw, 80px);
		align-items: end;
		padding: clamp(52px, 8vw, 106px) 0 34px;
	}

	.catalogue-hero .lead {
		padding-bottom: 10px;
	}

	.collection-rail {
		display: flex;
		gap: 0;
		margin-bottom: 26px;
		overflow-x: auto;
		border: 1px solid var(--line);
		background: var(--white);
	}

	.collection-rail a {
		display: inline-flex;
		align-items: center;
		gap: 14px;
		flex: 0 0 auto;
		min-height: 52px;
		border-right: 1px solid var(--line);
		padding: 12px 18px;
	}

	.collection-rail span {
		font-size: 0.78rem;
		font-weight: 800;
		text-transform: uppercase;
	}

	.collection-rail strong {
		color: var(--red);
		font-size: 0.78rem;
	}

	@media (max-width: 760px) {
		.catalogue-hero {
			grid-template-columns: 1fr;
			padding-top: 42px;
		}
	}
</style>
