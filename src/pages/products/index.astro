---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { collectionName, collectionPath, compareProductsForDisplay } from '../../lib/catalog';

const products = (await getCollection('products')).sort(compareProductsForDisplay);

const collectionCounts = products.reduce<Map<string, { count: number; path: string }>>((counts, product) => {
	const name = collectionName(product.data.category);
	const current = counts.get(name) ?? { count: 0, path: collectionPath(product.data.category) };
	current.count += 1;
	counts.set(name, current);
	return counts;
}, new Map());

const collections = [...collectionCounts.entries()].sort((a, b) => b[1].count - a[1].count || a[0].localeCompare(b[0]));
---

<BaseLayout title="Catalogue | Mirck" description="Browse the full Mirck Richard Mille catalogue by collection and reference.">
	<main class="page-shell catalogue-page">
		<section class="catalogue-hero" aria-labelledby="catalogue-title">
			<div>
				<p class="kicker">Full catalogue</p>
				<h1 id="catalogue-title" class="display-title">Richard Mille catalogue</h1>
			</div>
			<p class="lead">
				{products.length.toLocaleString('en-US')} products organized by family, with clean product cards and direct WhatsApp inquiry from every detail page.
			</p>
		</section>

		<nav class="collection-rail" aria-label="Collection counts">
			{
				collections.map(([name, data]) => (
					<a href={data.path}>
						<span>{name}</span>
						<strong>{data.count}</strong>
					</a>
				))
			}
		</nav>

		<div class="catalogue-tools" role="search">
			<label for="catalogue-search">Search references</label>
			<input id="catalogue-search" type="search" placeholder="Search RM 011, PMS011, collection, or title" autocomplete="off" />
			<span id="catalogue-count">{products.length.toLocaleString('en-US')} products</span>
		</div>

		<section class="product-grid" aria-label="Products" data-product-grid data-total={products.length}>
			{products.map((product, index) => <ProductCard product={product} priority={index < 8} />)}
		</section>
	</main>
</BaseLayout>

<script>
	const searchInput = document.querySelector<HTMLInputElement>('#catalogue-search');
	const countNode = document.querySelector<HTMLElement>('#catalogue-count');
	const productCards = [...document.querySelectorAll<HTMLElement>('[data-product-card]')];

	function updateCatalogueFilter() {
		const query = searchInput?.value.trim().toLowerCase() ?? '';
		let visible = 0;

		for (const card of productCards) {
			const haystack = [card.dataset.title, card.dataset.collection, card.dataset.sku].filter(Boolean).join(' ').toLowerCase();
			const match = !query || haystack.includes(query);
			card.hidden = !match;
			if (match) visible += 1;
		}

		if (countNode) {
			countNode.textContent = `${visible.toLocaleString('en-US')} products`;
		}
	}

	searchInput?.addEventListener('input', updateCatalogueFilter);
</script>

<style>
	.catalogue-page {
		padding-bottom: 110px;
	}

	.catalogue-hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 430px);
		gap: 72px;
		align-items: end;
		padding: clamp(46px, 7vw, 94px) 0 30px;
	}

	.catalogue-hero .display-title {
		max-width: 780px;
	}

	.catalogue-hero .lead {
		padding-bottom: 10px;
	}

	.collection-rail {
		display: flex;
		gap: 0;
		position: sticky;
		top: 72px;
		z-index: 30;
		margin-bottom: 24px;
		overflow-x: auto;
		border: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(14px);
	}

	.collection-rail a {
		display: inline-flex;
		align-items: center;
		gap: 14px;
		flex: 0 0 auto;
		min-height: 52px;
		border-right: 1px solid var(--line);
		padding: 12px 18px;
		transition: background 180ms ease;
	}

	.collection-rail a:hover {
		background: var(--paper);
	}

	.collection-rail span {
		font-size: 0.78rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.collection-rail strong {
		color: var(--red);
		font-size: 0.78rem;
		font-weight: 700;
	}

	.catalogue-tools {
		display: grid;
		grid-template-columns: auto minmax(260px, 1fr) auto;
		gap: 14px;
		align-items: center;
		margin-bottom: 24px;
		border: 1px solid var(--line);
		padding: 12px 14px;
		background: rgba(255, 255, 255, 0.7);
	}

	.catalogue-tools label,
	.catalogue-tools span {
		color: var(--muted);
		font-size: 0.72rem;
		font-weight: 800;
		text-transform: uppercase;
		white-space: nowrap;
	}

	.catalogue-tools input {
		width: 100%;
		min-height: 42px;
		border: 1px solid rgba(18, 18, 18, 0.15);
		border-radius: 999px;
		padding: 0 16px;
		background: var(--white);
		color: var(--ink);
		font: inherit;
	}

	.catalogue-tools input:focus {
		border-color: var(--red);
		outline: 0;
	}

	@media (max-width: 760px) {
		.catalogue-hero {
			grid-template-columns: 1fr;
			gap: 18px;
			padding-top: 42px;
		}

		.collection-rail {
			top: 108px;
		}

		.catalogue-tools {
			grid-template-columns: 1fr;
			gap: 8px;
		}
	}
</style>
