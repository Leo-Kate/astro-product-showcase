---
import { getCollection } from 'astro:content';

const products = (await getCollection('products')).sort((a, b) =>
	a.data.brand.localeCompare(b.data.brand) || a.data.title.localeCompare(b.data.title),
);

const brandCounts = products.reduce<Map<string, number>>((counts, product) => {
	counts.set(product.data.brand, (counts.get(product.data.brand) ?? 0) + 1);
	return counts;
}, new Map());

const brands = [...brandCounts.entries()].sort((a, b) => a[0].localeCompare(b[0]));
const productCountLabel = `${products.length.toLocaleString('en-US')} watches`;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Catalogue | Mirck</title>
		<meta name="description" content="Browse the full Mirck high-end watch catalogue by brand and reference." />
		<style>
			:root {
				color: #f4efe5;
				background: #090b0d;
				font-family:
					Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				font-size: 16px;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				background:
					radial-gradient(circle at 18% 0%, rgba(178, 134, 72, 0.18), transparent 28%),
					#090b0d;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			img {
				display: block;
			}

			.site-header,
			main {
				width: min(1240px, calc(100% - 32px));
				margin: 0 auto;
			}

			.site-header {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 24px;
				padding: 24px 0;
			}

			.brand-mark,
			.admin-link {
				font-size: 0.95rem;
				font-weight: 850;
				letter-spacing: 0.1em;
				text-transform: uppercase;
			}

			.admin-link {
				color: #d9d1c2;
			}

			.hero {
				display: flex;
				align-items: end;
				justify-content: space-between;
				gap: 24px;
				border-top: 1px solid rgba(244, 239, 229, 0.12);
				padding: 56px 0 34px;
			}

			.kicker {
				margin: 0 0 14px;
				color: #c89b5a;
				font-size: 0.78rem;
				font-weight: 850;
				letter-spacing: 0.18em;
				text-transform: uppercase;
			}

			h1 {
				margin: 0;
				font-size: clamp(2.8rem, 7vw, 6.6rem);
				line-height: 0.92;
			}

			.hero p:last-child {
				margin: 0;
				max-width: 360px;
				color: #a8a095;
				line-height: 1.7;
			}

			.brand-strip {
				display: flex;
				gap: 8px;
				overflow-x: auto;
				padding: 0 0 28px;
				margin-bottom: 8px;
			}

			.brand-chip {
				flex: 0 0 auto;
				border: 1px solid rgba(244, 239, 229, 0.13);
				border-radius: 999px;
				padding: 9px 12px;
				color: #d9d1c2;
				font-size: 0.84rem;
				font-weight: 750;
			}

			.product-grid {
				display: grid;
				grid-template-columns: repeat(5, minmax(0, 1fr));
				gap: 14px;
				padding-bottom: 76px;
			}

			.product-card {
				display: grid;
				grid-template-rows: auto 1fr;
				min-width: 0;
				border: 1px solid rgba(244, 239, 229, 0.12);
				border-radius: 8px;
				background: rgba(255, 255, 255, 0.035);
				overflow: hidden;
			}

			.product-card img {
				width: 100%;
				aspect-ratio: 1 / 1;
				object-fit: cover;
				background: #151719;
			}

			.product-card__body {
				display: grid;
				gap: 9px;
				padding: 13px;
			}

			.product-card__brand {
				color: #c89b5a;
				font-size: 0.72rem;
				font-weight: 850;
				letter-spacing: 0.1em;
				text-transform: uppercase;
			}

			.product-card h2 {
				margin: 0;
				font-size: 0.96rem;
				line-height: 1.3;
			}

			.product-card__meta {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 8px;
				margin-top: auto;
				color: #a8a095;
				font-size: 0.78rem;
				font-weight: 750;
			}

			@media (max-width: 1120px) {
				.product-grid {
					grid-template-columns: repeat(4, minmax(0, 1fr));
				}
			}

			@media (max-width: 840px) {
				.hero {
					align-items: flex-start;
					flex-direction: column;
				}

				.product-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
				}
			}

			@media (max-width: 520px) {
				.site-header {
					align-items: flex-start;
					flex-direction: column;
				}

				.product-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<header class="site-header">
			<a class="brand-mark" href="/">Mirck</a>
			<a class="admin-link" href="/admin/">CMS Admin</a>
		</header>

		<main>
			<section class="hero" aria-labelledby="catalogue-title">
				<div>
					<p class="kicker">Full Catalogue</p>
					<h1 id="catalogue-title">{productCountLabel}</h1>
				</div>
				<p>Browse every imported reference. Images load lazily to keep the catalogue responsive.</p>
			</section>

			<nav class="brand-strip" aria-label="Brand counts">
				{brands.map(([brand, count]) => <span class="brand-chip">{brand} · {count}</span>)}
			</nav>

			<section class="product-grid" aria-label="Products">
				{
					products.map((product) => (
						<a class="product-card" href={`/products/${product.id}/`}>
							<img src={product.data.image} alt={product.data.title} loading="lazy" />
							<div class="product-card__body">
								<span class="product-card__brand">{product.data.brand}</span>
								<h2>{product.data.title}</h2>
								<div class="product-card__meta">
									<span>{product.data.sku ?? 'Reference'}</span>
									<span>{product.data.in_stock ? 'Available' : 'Unavailable'}</span>
								</div>
							</div>
						</a>
					))
				}
			</section>
		</main>
	</body>
</html>
