---
import { whatsappHref } from '../lib/catalog';

const href = whatsappHref('Hi, I want to inquire about the Richard Mille catalogue.');
---

{
	href && (
		<a class="floating-whatsapp" href={href} aria-label="Contact Mirck on WhatsApp">
			<span class="floating-whatsapp__icon" aria-hidden="true">
				<svg viewBox="0 0 24 24" width="20" height="20" fill="none">
					<path
						d="M5.2 19.1l1-3.7a7.6 7.6 0 1 1 2.9 2.8l-3.9.9Z"
						stroke="currentColor"
						stroke-width="1.8"
						stroke-linejoin="round"
					/>
					<path
						d="M9.4 8.6c.2-.5.4-.5.7-.5h.5c.2 0 .4.1.5.4l.7 1.7c.1.3 0 .5-.2.7l-.4.5c.6 1 1.4 1.8 2.5 2.4l.5-.5c.2-.2.4-.3.7-.2l1.7.8c.3.1.4.3.4.6v.4c0 .4-.1.7-.5.9-.5.3-1.2.4-1.9.2-2.8-.8-5-2.8-6-5.5-.3-.8-.2-1.5.2-1.9Z"
						fill="currentColor"
					/>
				</svg>
			</span>
			<span class="floating-whatsapp__text">WhatsApp Inquiry</span>
		</a>
	)
}
